# Copie para .env.local (preferido) ou .env e preencha as chaves dos backends
# que você pretende usar. Nenhuma chave aqui é obrigatória em si — você só
# precisa das chaves para os backends que vai rodar com `medbench eval`.

# Backends nativos
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
# Alternativa aceita pelo provider Google (mesma credencial do Gemini)
GEMINI_API_KEY=

# Backends via provider OpenAI-compatível
MARITACA_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=
