{
  "name": "@precisa-saude/medbench-harness",
  "version": "1.3.0",
  "description": "Harness reproduzível de avaliação de LLMs em provas médicas brasileiras",
  "keywords": [
    "llm",
    "benchmark",
    "evaluation",
    "medical",
    "brazil",
    "revalida"
  ],
  "homepage": "https://github.com/Precisa-Saude/medbench-brasil/tree/main/packages/eval-harness#readme",
  "bugs": "https://github.com/Precisa-Saude/medbench-brasil/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/Precisa-Saude/medbench-brasil.git",
    "directory": "packages/eval-harness"
  },
  "license": "Apache-2.0",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./prompt": {
      "import": {
        "types": "./dist/prompt.d.ts",
        "default": "./dist/prompt.js"
      },
      "require": {
        "types": "./dist/prompt.d.cts",
        "default": "./dist/prompt.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "medbench": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .turbo",
    "lint": "eslint src/ --max-warnings 0",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@precisa-saude/medbench-dataset": "workspace:*",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "~5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
