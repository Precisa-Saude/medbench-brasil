{
  "name": "@medbench-brasil/ingestion",
  "version": "0.1.0",
  "private": true,
  "description": "Pipeline de ingestão: download de provas INEP, extração via @kreuzberg/node (Tesseract por+eng), parsing estruturado via Claude tool_use",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "medbench-ingest": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .turbo",
    "lint": "eslint src/ --max-warnings 0",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kreuzberg/node": "^4.0.8",
    "@precisa-saude/medbench-dataset": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "~5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
