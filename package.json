{
  "name": "medbench-brasil",
  "version": "1.3.0",
  "private": true,
  "description": "Leaderboard contínuo de desempenho de LLMs em provas médicas brasileiras",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "prepare": "husky",
    "release": "semantic-release",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "typecheck": "turbo run typecheck"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings 0 --no-warn-ignored"
    ],
    "*.{js,jsx,json,md,css,html}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@precisa-saude/commitlint-config": "^1.0.3",
    "@precisa-saude/eslint-config": "^1.0.3",
    "@precisa-saude/prettier-config": "^1.0.3",
    "@precisa-saude/tsconfig": "^1.0.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@types/node": "^20.17.12",
    "@vitest/coverage-v8": "^2.1.8",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2",
    "prettier-plugin-packagejson": "^3.0.2",
    "semantic-release": "^25.0.3",
    "tsup": "^8.3.5",
    "turbo": "^2.3.3",
    "typescript": "~5.7.3",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  }
}
